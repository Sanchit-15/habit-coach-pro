# Copy this file to server/.env and fill in real values.
# The .env file should NEVER be committed to git.

# Local MongoDB (default). Or use a MongoDB Atlas connection string.
MONGODB_URI=mongodb://localhost:27017/consistify

# Any long random string. Used to sign JWT tokens.
JWT_SECRET=change_me_to_a_long_random_string

# Port the Express server listens on.
PORT=5000
